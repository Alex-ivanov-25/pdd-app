{
  "expo": {
    "name": "ПДД",
    "slug": "pdd-app",
    "version": "1.0.0",
    "ios": {
      "bundleIdentifier": "com.yourname.pdd",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "audio",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Нужно для чтения скриншотов"
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "20615b49-5d2f-4a03-8de7-f021b1b919f7"
      }
    },
    "android": {
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.yourname.pdd"
    }
  }
}
